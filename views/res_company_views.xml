<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_raet" model="ir.ui.view">
        <field name="name">res.company.form.raet</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Integración RAET" name="raet_group">
                    <field name="raet_tenant_id"/>
                    <field name="raet_sync_enabled"/>
                    <field name="raet_last_sync" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
