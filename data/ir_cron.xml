<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_cron_raet_sync" model="ir.cron">
        <field name="name">RAET: Sincronizar padrón de empleados</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="state">code</field>
        <field name="code">model._cron_raet_sync()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="False"/>
    </record>

    <record id="ir_cron_raet_process_queue" model="ir.cron">
        <field name="name">RAET: Procesar cola de sincronización</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="state">code</field>
        <field name="code">model._cron_raet_process_queue()</field>
        <field name="interval_number">30</field>
        <field name="interval_type">minutes</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
